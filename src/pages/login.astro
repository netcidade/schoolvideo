---
import MainLayout from '../layouts/MainLayout.astro';
import { getSession, login } from '../lib/auth';
import { getLang, useTranslations } from '../lib/i18n';

// Redirecionar se já logado
const cfEnv = Astro.locals.runtime?.env || {};
const user = await getSession(Astro.cookies, cfEnv);
if (user) return Astro.redirect('/');

const lang = getLang(Astro.cookies, Astro.url);
const t = useTranslations(lang);

let error = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const email = form.get('email')?.toString() ?? '';
  const senha  = form.get('senha')?.toString()  ?? '';
  const result = await login(email, senha, Astro.cookies, cfEnv);
  if (result.ok) {
    const redirect = new URL(Astro.request.url).searchParams.get('redirect') ?? `/`;
    return Astro.redirect(redirect);
  }
  error = lang === 'en' ? 'Invalid email or password.' : 'E-mail ou senha inválidos.';
}
---
<MainLayout title={t('login')}>
  <div style="min-height:100vh; display:flex; align-items:center; justify-content:center; padding:2rem;">
    <div style="width:100%; max-width:420px;">
      <div style="text-align:center; margin-bottom:2.5rem;">
        <div class="section-label">{t('welcome_back')}</div>
        <h1 style="font-family:'Cormorant Garamond',serif; font-size:2.5rem; font-weight:300; color:var(--cream);">
          {t('login')}
        </h1>
      </div>

      {error && <div class="alert alert-error">{error}</div>}

      <form method="POST" style="display:flex; flex-direction:column; gap:1rem;">
        <div class="form-group">
          <label class="form-label" for="email">{t('email')}</label>
          <input class="form-input" type="email" id="email" name="email" required
                 placeholder="seu@email.com" autocomplete="email" />
        </div>
        <div class="form-group">
          <label class="form-label" for="senha">{t('password')}</label>
          <div style="position:relative;">
            <input class="form-input" type="password" id="senha" name="senha" required
                   placeholder="••••••••" autocomplete="current-password" style="padding-right:3rem;" />
            <button type="button" id="toggle-senha" style="position:absolute; right:1rem; top:50%; transform:translateY(-50%); background:none; border:none; color:var(--muted); cursor:pointer; padding:0.25rem; display:flex; align-items:center;">
              <svg id="eye-open" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              <svg id="eye-closed" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
            </button>
          </div>
        </div>
        <button type="submit" class="btn-primary" style="justify-content:center; margin-top:0.5rem;">
          {t('login')}
        </button>
      </form>

      <p style="text-align:center; margin-top:1.5rem; font-size:0.85rem; color:var(--muted);">
        {t('no_account')}
        <a href={`/registro?lang=${lang}`} style="color:var(--gold); text-decoration:none;">{t('create_account')}</a>
      </p>
    </div>
  </div>
<script>
  const toggleBtn = document.getElementById('toggle-senha');
  const senhaInput = document.getElementById('senha') as HTMLInputElement;
  const eyeOpen = document.getElementById('eye-open');
  const eyeClosed = document.getElementById('eye-closed');

  if (toggleBtn && senhaInput && eyeOpen && eyeClosed) {
    toggleBtn.addEventListener('click', () => {
      const isPass = senhaInput.type === 'password';
      senhaInput.type = isPass ? 'text' : 'password';
      eyeOpen.style.display = isPass ? 'none' : 'block';
      eyeClosed.style.display = isPass ? 'block' : 'none';
      toggleBtn.style.color = isPass ? 'var(--gold)' : 'var(--muted)';
    });
  }
</script>
</MainLayout>
