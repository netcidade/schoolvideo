---
import type { SessionUser } from '../lib/auth';
import { getLang, useTranslations } from '../lib/i18n';

interface Props {
  user?: SessionUser | null;
}
const { user } = Astro.props;
const path = Astro.url.pathname;
const lang = getLang(Astro.cookies, Astro.url);
const t    = useTranslations(lang);
---
<header class="site-header" id="site-header">
  <div style="display:flex;align-items:center;gap:2rem;">
    <a href={`/?lang=${lang}`} class="logo">
      <div class="logo-dot"></div>
      ESCOLA EM VÍDEO
    </a>

    <ul class="nav-links">
      <li><a href={`/?lang=${lang}`} class={path === '/' ? 'active' : ''}>{t('catalog')}</a></li>
      {user && <li><a href={`/biblioteca?lang=${lang}`} class={path.startsWith('/biblioteca') ? 'active' : ''}>{t('library')}</a></li>}
      {user?.role === 'admin' && <li><a href="/admin" style="color:var(--gold);font-weight:600;">{t('admin')}</a></li>}
    </ul>
  </div>

  <div style="display:flex; align-items:center; gap:1.5rem;">
    <!-- i18n switch -->
    <div style="display:flex;gap:4px;font-size:0.75rem;">
      <a href="?lang=en" style={`color:${lang === 'en' ? 'var(--gold)' : 'var(--muted)'};text-decoration:none;font-weight:${lang === 'en' ? 'bold' : 'normal'}`}>EN</a>
      <span style="color:var(--border)">|</span>
      <a href="?lang=pt" style={`color:${lang === 'pt' ? 'var(--gold)' : 'var(--muted)'};text-decoration:none;font-weight:${lang === 'pt' ? 'bold' : 'normal'}`}>PT</a>
    </div>

    <div style="display:flex; align-items:center; gap:1rem;">
      {user ? (
        <>
          <span style="font-size:0.82rem; color:var(--muted);">
            {t('hello')}, <strong style="color:var(--cream);">{user.nome}</strong>
          </span>
          <a href="/logout" style="font-size:0.82rem; color:var(--muted); text-decoration:none; border:1px solid rgba(255,255,255,0.12); border-radius:6px; padding:4px 12px;">
            {t('logout')}
          </a>
        </>
      ) : (
        <a href={`/login?lang=${lang}`} style="font-size:0.85rem; color:var(--cream); text-decoration:none; border:1px solid rgba(201,168,76,0.4); border-radius:6px; padding:6px 16px;">
          {t('login')}
        </a>
      )}

      <button class="btn-cart" id="cart-open-btn">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
        </svg>
        {t('cart')}
        <span class="cart-count" id="cart-count">0</span>
      </button>
    </div>
  </div>
</header>


<script>
const header = document.getElementById('site-header');
window.addEventListener('scroll', () => {
  header?.classList.toggle('scrolled', window.scrollY > 60);
});
</script>
