---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { requireAdmin } from '../../lib/auth';
import { createAdminClient, DB_ID, COLLECTIONS, BUCKET_ID } from '../../lib/appwrite';
import { Query, ID } from 'node-appwrite';

const cfEnv = Astro.locals.runtime?.env || {};
const dynamicDbId = cfEnv.APPWRITE_DATABASE_ID || DB_ID;
const user = await requireAdmin(Astro.cookies, cfEnv);
const { databases, storage } = await createAdminClient(cfEnv);

let msg = '';
let err = '';

// ── PROCESSAR ACTIONS ──────────────────────────────────────
if (Astro.request.method === 'POST') {
  const form   = await Astro.request.formData();
  const action = form.get('action')?.toString();

  if (action === 'delete') {
    const id   = form.get('id')?.toString() ?? '';
    const prof = await databases.getDocument(dynamicDbId, COLLECTIONS.PROFESSORES, id);
    if (prof.foto_id) {
      try { await storage.deleteFile(BUCKET_ID, prof.foto_id); } catch {}
    }
    await databases.deleteDocument(dynamicDbId, COLLECTIONS.PROFESSORES, id);
    msg = 'Professor removido.';
  } else if (action === 'add' || action === 'edit') {
    // Upload de foto
    let fotoId = form.get('foto_id_atual')?.toString() ?? undefined;
    const fotoFile = form.get('foto') as File | null;
    if (fotoFile && fotoFile.size > 0) {
      const uploaded = await storage.createFile(
        BUCKET_ID, ID.unique(),
        fotoFile
      );
      fotoId = uploaded.$id;
    }

    const data = {
      nome:          form.get('nome')?.toString()         ?? '',
      especialidade: form.get('especialidade')?.toString() ?? '',
      bio:           form.get('bio')?.toString()           ?? '',
      bio_en:        form.get('bio_en')?.toString()        ?? '',
      email:         form.get('email')?.toString()         ?? '',
      whatsapp:      form.get('whatsapp')?.toString()      ?? '',
      endereco:      form.get('endereco')?.toString()      ?? '',
      cidade:        form.get('cidade')?.toString()        ?? '',
      estado:        form.get('estado')?.toString()        ?? '',
      pais:          form.get('pais')?.toString()          ?? 'Brasil',
      cor_tema:      form.get('cor_tema')?.toString()      ?? '#C9A84C',
      foto_id:       fotoId,
    };

    if (action === 'add') {
      await databases.createDocument(dynamicDbId, COLLECTIONS.PROFESSORES, ID.unique(), data);
      msg = 'Professor adicionado!';
    } else {
      const id = form.get('id')?.toString() ?? '';
      await databases.updateDocument(dynamicDbId, COLLECTIONS.PROFESSORES, id, data);
      msg = 'Professor atualizado!';
    }
  }
  return Astro.redirect('/admin/professores' + (msg ? '?ok=1' : ''));
}

if (Astro.url.searchParams.get('ok')) msg = 'Operação realizada com sucesso!';

const professores = (await databases.listDocuments(dynamicDbId, COLLECTIONS.PROFESSORES, [
  Query.orderAsc('nome'), Query.limit(100),
])).documents;

// Edição
let editProf: any = null;
const editId = Astro.url.searchParams.get('edit');
if (editId) editProf = await databases.getDocument(dynamicDbId, COLLECTIONS.PROFESSORES, editId);

const endpoint  = import.meta.env.APPWRITE_ENDPOINT;
const projectId = import.meta.env.APPWRITE_PROJECT_ID;
function fotoUrl(prof: any) {
  return prof.foto_id
    ? `${endpoint}/storage/buckets/${BUCKET_ID}/files/${prof.foto_id}/view?project=${projectId}`
    : null;
}
---
<AdminLayout title={editProf ? 'Editar Professor' : 'Professores'} user={user} currentPage="/admin/professores">
  {msg && <div class="alert alert-success">✅ {msg}</div>}

  <div style="margin-bottom:1.5rem;">
    <button type="button" class="btn btn-gold" onclick="toggleForm()" id="btnToggleForm">
      {editProf ? '✖ Fechar' : '➕ Novo Professor'}
    </button>
  </div>

  <!-- FORMULÁRIO -->
  <div class="form-card" id="formProf" style={`display:${editProf ? 'block' : 'none'};border-color:var(--gold);`}>
    <div class="form-card-title">{editProf ? '✏️ Editar Professor' : '➕ Novo Professor'}</div>
    <form method="POST" enctype="multipart/form-data">
      <input type="hidden" name="action" value={editProf ? 'edit' : 'add'} />
      {editProf && <input type="hidden" name="id" value={editProf.$id} />}
      {editProf && <input type="hidden" name="foto_id_atual" value={editProf.foto_id ?? ''} />}

      <div class="form-grid">
        <div class="form-group" style="grid-column:span 2">
          <label class="form-label">Foto</label>
          <input class="form-input" type="file" name="foto" accept="image/*" />
        </div>
        <div class="form-group" style="grid-column:span 2">
          <label class="form-label">Nome *</label>
          <input class="form-input" type="text" name="nome" required value={editProf?.nome ?? ''} />
        </div>
        <div class="form-group">
          <label class="form-label">Especialidade *</label>
          <input class="form-input" type="text" name="especialidade" required value={editProf?.especialidade ?? ''} />
        </div>
        <div class="form-group">
          <label class="form-label">Cor do Tema</label>
          <input class="form-input" type="color" name="cor_tema" value={editProf?.cor_tema ?? '#C9A84C'} style="height:40px;cursor:pointer;padding:2px;" />
        </div>
        <div class="form-group">
          <label class="form-label">E-mail</label>
          <input class="form-input" type="email" name="email" value={editProf?.email ?? ''} />
        </div>
        <div class="form-group">
          <label class="form-label">WhatsApp (com DDI)</label>
          <input class="form-input" type="tel" name="whatsapp" value={editProf?.whatsapp ?? ''} placeholder="5511999998888" />
        </div>
        <div class="form-group full">
          <label class="form-label">Endereço</label>
          <input class="form-input" type="text" name="endereco" value={editProf?.endereco ?? ''} />
        </div>
        <div class="form-group">
          <label class="form-label">Cidade</label>
          <input class="form-input" type="text" name="cidade" value={editProf?.cidade ?? ''} />
        </div>
        <div class="form-group">
          <label class="form-label">Estado / País</label>
          <input class="form-input" type="text" name="estado" value={editProf?.estado ?? ''} />
        </div>
        <div class="form-group full">
          <label class="form-label">Bio (PT)</label>
          <textarea class="form-textarea" name="bio" rows={3}>{editProf?.bio ?? ''}</textarea>
        </div>
        <div class="form-group full">
          <label class="form-label">Bio (EN)</label>
          <textarea class="form-textarea" name="bio_en" rows={3}>{editProf?.bio_en ?? ''}</textarea>
        </div>
      </div>
      <div style="display:flex;gap:.75rem;margin-top:1.25rem;">
        <button type="submit" class="btn btn-gold">{editProf ? 'Salvar' : 'Adicionar'}</button>
        {editProf && <a href="/admin/professores" class="btn btn-ghost">Cancelar</a>}
      </div>
    </form>
  </div>

  <!-- TABELA -->
  <div class="admin-table-wrap">
    <div class="admin-table-header">
      <span class="admin-table-title">Professores Cadastrados</span>
      <span style="font-size:.8rem;color:var(--muted);">{professores.length} professor(es)</span>
    </div>
    {professores.length === 0 ? (
      <div style="padding:2rem;text-align:center;color:var(--muted);">Nenhum professor cadastrado.</div>
    ) : (
      <table>
        <thead><tr><th>Professor</th><th>Especialidade</th><th>Cor</th><th>Ações</th></tr></thead>
        <tbody>
          {professores.map(p => (
            <tr>
              <td>
                <div style="display:flex;align-items:center;gap:.75rem;">
                  {fotoUrl(p)
                    ? <img src={fotoUrl(p)!} style="width:36px;height:36px;border-radius:50%;object-fit:cover;" alt="" />
                    : <div style={`width:36px;height:36px;border-radius:50%;background:${p.cor_tema}22;display:flex;align-items:center;justify-content:center;font-size:.7rem;color:${p.cor_tema};font-weight:700;`}>{p.nome.slice(0,2).toUpperCase()}</div>
                  }
                  <strong>{p.nome}</strong>
                </div>
              </td>
              <td style="color:var(--muted);">{p.especialidade}</td>
              <td><span class="color-swatch" style={`background:${p.cor_tema};`}></span></td>
              <td>
                <div style="display:flex;gap:.5rem;">
                  <a href={`/admin/professores?edit=${p.$id}`} class="btn btn-ghost btn-sm">Editar</a>
                  <form method="POST" onsubmit="return confirm('Remover professor?')">
                    <input type="hidden" name="action" value="delete" />
                    <input type="hidden" name="id" value={p.$id} />
                    <button type="submit" class="btn btn-danger btn-sm">Remover</button>
                  </form>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>
</AdminLayout>

<script>
function toggleForm() {
  const form = document.getElementById('formProf')!;
  const btn  = document.getElementById('btnToggleForm')!;
  if (form.style.display === 'none') {
    form.style.display = 'block';
    btn.textContent = '✖ Fechar Formulário';
  } else {
    form.style.display = 'none';
    btn.textContent = '➕ Novo Professor';
  }
}
</script>
