---
import MainLayout from '../../layouts/MainLayout.astro';
import { getSession } from '../../lib/auth';
import { createAdminClient, DB_ID, COLLECTIONS } from '../../lib/appwrite';
import { Query } from 'node-appwrite';
import { getLang, useTranslations } from '../../lib/i18n';

const { id } = Astro.params;
const cfEnv = Astro.locals.runtime?.env || {};
const user = await getSession(Astro.cookies, cfEnv);
const lang = getLang(Astro.cookies, Astro.url);
const t = useTranslations(lang);

const { databases } = await createAdminClient(cfEnv);
const dynamicDbId = cfEnv.APPWRITE_DATABASE_ID || DB_ID;

let professor: any = null;
let videos: any[]  = [];

try {
  professor = await databases.getDocument(dynamicDbId, COLLECTIONS.PROFESSORES, id!);
  const res = await databases.listDocuments(dynamicDbId, COLLECTIONS.VIDEOS, [
    Query.equal('professor_id', id!), Query.orderAsc('preco'),
  ]);
  videos = res.documents;
} catch {
  return Astro.redirect('/');
}

// Verificar quais vídeos o usuário já comprou
let comprados = new Set<string>();
if (user) {
  try {
    const res = await databases.listDocuments(dynamicDbId, COLLECTIONS.COMPRAS, [
      Query.equal('usuario_id', user.id),
      Query.equal('status', 'pago'),
    ]);
    res.documents.forEach(c => comprados.add(c.video_id));
  } catch {}
}

const hash = id ? id.split('').reduce((acc, c) => acc + c.charCodeAt(0), 0) : 0;
const bgIndex = (hash % 4) + 1;
const endpoint = cfEnv.APPWRITE_ENDPOINT || import.meta.env.APPWRITE_ENDPOINT;
const projId = cfEnv.APPWRITE_PROJECT_ID || import.meta.env.APPWRITE_PROJECT_ID;

const fotoUrl = professor.foto_id
  ? `${endpoint}/storage/buckets/professor-photos/files/${professor.foto_id}/view?project=${projId}`
  : `/assets/img/prof_${bgIndex}.webp`;
---
<MainLayout title={professor.nome} user={user}>
  <!-- GLOBAL FIXED BACKGROUND E OVERLAY -->
  <div class="hero-bg" id="prof-bg" style={`background-image:url('${fotoUrl}'); position:fixed; inset:0; z-index:-2; background-size:cover; background-position:center top;`}></div>
  <div class="hero-overlay" id="prof-overlay" style="position:fixed; inset:0; z-index:-1; background:linear-gradient(to bottom, rgba(11,11,15,0.2) 0%, rgba(11,11,15,1) 100%);"></div>

  <!-- HERO DO PROFESSOR (Vazado para revelar o fundo fixo) -->
  <section style="min-height:70vh; display:flex; align-items:flex-end; padding:0 2rem 4rem; position:relative; background:transparent;">
    <div style="position:relative;z-index:1;max-width:700px;">
      <span class="prof-tag reveal" style={`color:${professor.cor_tema};border-color:${professor.cor_tema}44;background:${professor.cor_tema}15;`}>
        {professor.especialidade}
      </span>
      <h1 style="font-family:'Cormorant Garamond',serif;font-size:clamp(2.5rem,6vw,4.5rem);font-weight:300;color:var(--cream);margin:1rem 0;">
        {professor.nome}
      </h1>
      <p style="color:var(--muted);max-width:560px;line-height:1.75;">{professor.bio}</p>
    </div>
  </section>

  <!-- CONTEÚDO RESTANTE (Fundo escuro para rolar por cima do Hero fixo) -->
  <div style="background:var(--bg-dark); position:relative; z-index:2; padding-top:4rem; padding-bottom:6rem; min-height:50vh;">
    <!-- AULAS -->
    <div class="section">
    <div class="reveal">
      <div class="section-label">{t('avail_classes')}</div>
      <h2 class="section-title">{t('catalog')} de {professor.nome}</h2>
    </div>

    <div class="video-list">
      {videos.map((v) => {
        const bought  = comprados.has(v.$id);
        const isFree  = v.preco === 0 || v.is_preview;
        return (
          <div class="video-row reveal">
            <div class="video-icon-box">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            </div>
            <div class="video-info">
              <h3 class="video-title">{v.titulo}</h3>
              <p class="video-desc">{v.descricao}</p>
              <div class="video-meta">
                {v.is_preview && <span class="tag-preview">{t('free_preview')}</span>}
                {bought && <span class="tag-purchased">Adquirido</span>}
                <span>{v.duracao}</span>
              </div>
            </div>
            <div style="display:flex; align-items:center; gap:1.5rem;">
              <span class={isFree ? 'video-price free-price' : 'video-price'}>
                {v.preco === 0 ? t('free') : `$${v.preco.toFixed(2)}`}
              </span>
              {isFree || bought || user ? (
                <button class="btn-watch" onclick={`location.href='/watch/${v.$id}?lang=${lang}'`}>{t('watch')}</button>
              ) : (
                <button class="btn-buy" onclick={`addToCart('${v.$id}', '${v.titulo}', '${professor.nome}', ${v.preco}, this)`}>{t('add_to_cart')}</button>
              )}
            </div>
          </div>
        );
      })}
    </div>
  </div>
    </div>
  </div>
</MainLayout>

<script define:vars={{ txtInCart: t('in_cart') }}>
  window.txtInCart = txtInCart;
</script>

<script>
  async function addToCart(id: string, titulo: string, prof: string, preco: number, btn: HTMLButtonElement) {
    const fd = new FormData();
    fd.append('action', 'add');
    fd.append('video_id', id);
    fd.append('titulo', titulo);
    fd.append('prof', prof);
    fd.append('preco', String(preco));

    btn.disabled = true;
    btn.textContent = '...';

    await fetch('/api/cart', { method: 'POST', body: fd });
    
    btn.textContent = window.txtInCart;
    btn.classList.replace('btn-buy', 'btn-in-cart');
    
    const res = await fetch('/api/cart');
    const data = await res.json();
    const count = document.getElementById('cart-count');
    if (count) {
      count.textContent = data.count;
      count.classList.toggle('show', data.count > 0);
    }
  }
  (window as any).addToCart = addToCart;

  const observer = new IntersectionObserver(
    entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.1 }
  );
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

  // Efeito Parallax + Fade do Hero do Professor
  const profBg = document.getElementById('prof-bg');
  const profOverlay = document.getElementById('prof-overlay');
  
  if (profBg && profOverlay) {
    window.addEventListener('scroll', () => {
      const scrollY = window.scrollY;
      const progress = Math.min(scrollY / 600, 1);
      const baseOpacity = 0.2;
      const targetOpacity = 0.95;
      const currentOpacity = baseOpacity + (targetOpacity - baseOpacity) * progress;
      
      profOverlay.style.background = `linear-gradient(to bottom, rgba(11,11,15,${currentOpacity}) 0%, rgba(11,11,15,1) 100%)`;
      // Parallax sutil no fundo
      profBg.style.transform = `translateY(${scrollY * 0.3}px)`;
    });
  }
</script>
