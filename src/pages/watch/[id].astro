---
import MainLayout from '../../layouts/MainLayout.astro';
import { requireLogin } from '../../lib/auth';
import { createAdminClient, DB_ID, COLLECTIONS } from '../../lib/appwrite';
import { Query } from 'node-appwrite';
import { getLang, useTranslations } from '../../lib/i18n';

const { id } = Astro.params;
const cfEnv = Astro.locals.runtime?.env || {};
const dynamicDbId = cfEnv.APPWRITE_DATABASE_ID || DB_ID;
const user = await requireLogin(Astro.cookies, `/watch/${id}`, cfEnv);
const lang = getLang(Astro.cookies, Astro.url);
const t    = useTranslations(lang);

const { databases } = await createAdminClient(cfEnv);

let video: any = null;
let professor: any = null;
let hasAccess = false;

try {
  video = await databases.getDocument(dynamicDbId, COLLECTIONS.VIDEOS, id!);
  
  // Verificar acesso: se for grátis OU se o usuário comprou
  if (video.preco === 0 || video.is_preview) {
    hasAccess = true;
  } else {
    const compra = await databases.listDocuments(dynamicDbId, COLLECTIONS.COMPRAS, [
      Query.equal('usuario_id', user.id),
      Query.equal('video_id', id!),
      Query.equal('status', 'pago'),
      Query.limit(1)
    ]);
    if (compra.total > 0 || user.role === 'admin') {
      hasAccess = true;
    }
  }

  if (video.professor_id) {
    professor = await databases.getDocument(dynamicDbId, COLLECTIONS.PROFESSORES, video.professor_id);
  }

  if (!hasAccess) {
    return Astro.redirect(`/?lang=${lang}`);
  }
} catch {
  return Astro.redirect(`/?lang=${lang}`);
}
---

<MainLayout title={`Assistindo: ${video.titulo}`} user={user}>
  <div style="min-height:100vh; padding-top: 100px; background: #000;">
    <div style="max-width:1200px; margin:0 auto; padding:0 2rem;">
      <!-- PLAYER -->
      <div style="aspect-ratio:16/9; background:#111; border-radius:12px; overflow:hidden; box-shadow: 0 30px 60px rgba(0,0,0,0.8); border:1px solid rgba(255,255,255,0.05);">
        {video.video_url ? (
          <iframe 
            src={video.video_url.includes('youtube.com') ? video.video_url.replace('watch?v=', 'embed/') : video.video_url} 
            style="width:100%; height:100%; border:0;"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
            allowfullscreen
          ></iframe>
        ) : (
          <div style="display:flex; flex-direction:column; align-items:center; justify-content:center; height:100%; color:var(--muted);">
             <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" style="margin-bottom:1rem; opacity:0.3;"><path d="M22 12H2M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg>
             <p>URL de vídeo não configurada no banco de dados.</p>
          </div>
        )}
      </div>

      <!-- INFO -->
      <div style="margin-top:3rem; padding-bottom:5rem;">
        <div style="display:flex; justify-content:space-between; align-items:flex-start; flex-wrap:wrap; gap:2rem;">
          <div style="flex:1; min-width:300px;">
            <div class="section-label" style="margin-bottom:0.5rem;">{professor?.nome}</div>
            <h1 style="font-family:'Cormorant Garamond',serif; font-size:2.8rem; font-weight:300; color:var(--cream); margin-bottom:1.5rem;">{video.titulo}</h1>
            <p style="color:var(--muted); line-height:1.8; font-size:1.1rem; max-width:800px;">{video.descricao}</p>
          </div>
          
          <div style="width:100%; max-width:320px; background:rgba(255,255,255,0.03); border:1px solid var(--border); border-radius:12px; padding:1.5rem;">
            <h3 style="font-size:1rem; color:var(--gold); margin-bottom:1rem; text-transform:uppercase; letter-spacing:1px;">Próximos Passos</h3>
            <p style="font-size:0.85rem; color:var(--muted); line-height:1.6; margin-bottom:1.5rem;">
               Após assistir a esta aula, explore outros mestres no nosso catálogo completo de ritmos brasileiros.
            </p>
            <a href="/" class="btn-primary" style="width:100%; justify-content:center;">Voltar ao Catálogo</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</MainLayout>
