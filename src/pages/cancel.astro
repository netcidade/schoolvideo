---
import MainLayout from '../layouts/MainLayout.astro';
import { getLang, useTranslations } from '../lib/i18n';
import { getSession } from '../lib/auth';

const cfEnv = Astro.locals.runtime?.env || {};
const user = await getSession(Astro.cookies, cfEnv);
const lang = getLang(Astro.cookies, Astro.url);
const t    = useTranslations(lang);
---

<MainLayout title="Cancelado" user={user}>
  <div style="min-height:90vh; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:2rem; text-align:center;">
    <div style="width:100px; height:100px; background:rgba(255,255,255,0.05); border:1px solid var(--border); border-radius:50%; display:flex; align-items:center; justify-content:center; margin-bottom:2rem;">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--muted)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </div>
    
    <div class="section-label">PAGAMENTO CANCELADO</div>
    <h1 style="font-family:'Cormorant Garamond',serif; font-size:3.5rem; color:var(--cream); margin-bottom:1.5rem; font-weight:300;">Compra não finalizada</h1>
    <p style="color:var(--muted); max-width:500px; line-height:1.7; margin-bottom:2.5rem;">
      Você cancelou o processo de pagamento. Suas aulas continuam no seu carrinho caso mude de ideia. Em caso de dúvidas, entre em contato com nosso suporte.
    </p>

    <div style="display:flex; gap:1.5rem; flex-wrap:wrap; justify-content:center;">
      <a href="/" class="btn-primary">Voltar ao Catálogo</a>
    </div>
  </div>
</MainLayout>
